<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Sign Up — Cartify</title>
  <link rel="stylesheet" href="/css/style.css">
  <script>
    (function () {
      const saved = localStorage.getItem('cartify-theme');
      if (saved === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    })();
  </script>
  <script src="/js/theme.js"></script>
</head>
<body>

    <header class="site-header">
        <a href="/" class="logo">Cartify</a>
        <nav class="header-nav">
          <button onclick="toggleTheme()" class="theme-toggle">🌙</button>
          <a href="/cart">Cart</a>
          <% if (currentUser) { %>
            <span class="user-greeting">Hi, <%= currentUser.name %></span>
            <form action="/logout" method="POST" class="logout-form">
              <button type="submit" class="link-btn">Logout</button>
            </form>
          <% } else { %>
            <a href="/login">Login</a>
          <% } %>
        </nav>
      </header>

  <div class="auth-page">
    <h1>Create an account</h1>

    <% if (error) { %>
      <p class="auth-error"><%= error %></p>
    <% } %>

    <form action="/signup" method="POST" class="auth-form">
      <label for="name">Name</label>
      <input type="text" id="name" name="name" required>

      <label for="email">Email</label>
      <input type="email" id="email" name="email" required>

      <label for="password">Password</label>
      <input type="password" id="password" name="password" required minlength="6">

      <button type="submit" class="btn-primary">Sign Up</button>
    </form>

    <p class="auth-switch">Already have an account? <a href="/login">Log in</a></p>
  </div>

</body>
</html>