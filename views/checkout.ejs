<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Checkout — Cartify</title>
  <link rel="stylesheet" href="/css/style.css">
  <script>
    (function () {
      const saved = localStorage.getItem('cartify-theme');
      if (saved === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    })();
  </script>
  <script src="/js/theme.js"></script>
</head>
<body>

    <header class="site-header">
        <a href="/" class="logo">Cartify</a>
        <nav class="header-nav">
          <button onclick="toggleTheme()" class="theme-toggle">🌙</button>
          <a href="/cart">Cart</a>
          <% if (currentUser) { %>
            <a href="/my-orders">My Orders</a>
            <span class="user-greeting">Hi, <%= currentUser.name %></span>
            <form action="/logout" method="POST" class="logout-form">
              <button type="submit" class="link-btn">Logout</button>
            </form>
          <% } else { %>
            <a href="/login">Login</a>
          <% } %>
        </nav>
      </header>

  <div class="checkout-page">
    <h1>Checkout</h1>

    <% if (error) { %>
      <p class="auth-error"><%= error %></p>
    <% } %>

    <div class="checkout-layout">

      <form action="/checkout" method="POST" class="checkout-form">
        <h2>Shipping Address</h2>

        <label for="full_name">Full Name</label>
        <input type="text" id="full_name" name="full_name" value="<%= currentUser.name %>" required>

        <label for="phone">Phone Number</label>
        <input type="tel" id="phone" name="phone" required>

        <label for="address_line">Address</label>
        <input type="text" id="address_line" name="address_line" placeholder="House no, street, area" required>

        <label for="city">City</label>
        <input type="text" id="city" name="city" required>

        <label for="pincode">Pincode</label>
        <input type="text" id="pincode" name="pincode" required>

        <h2>Payment Method</h2>
        <div class="payment-options">
          <label class="payment-option">
            <input type="radio" name="payment_method" value="online" checked>
            <span>Pay Online (Card/UPI)</span>
          </label>
          <label class="payment-option">
            <input type="radio" name="payment_method" value="cod">
            <span>Cash on Delivery</span>
          </label>
        </div>

        <button type="submit" class="btn-primary">Place Order</button>
      </form>

      <div class="checkout-summary">
        <h2>Order Summary</h2>
        <% cartItems.forEach(function(item) { %>
          <div class="summary-item">
            <span><%= item.name %> × <%= item.quantity %></span>
            <span>₹<%= item.subtotal %></span>
          </div>
        <% }); %>
        <div class="summary-total">
          <span>Total</span>
          <span>₹<%= total %></span>
        </div>
      </div>

    </div>
  </div>

</body>
</html>